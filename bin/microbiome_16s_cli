#!/bin/bash

# ==============================================================================
# microbiome_16s_cli
# 단일 명령어로 QIIME2 16S 파이프라인 (Beta 다양성 분석까지) 실행
# ==============================================================================

function show_help {
    echo "Usage: microbiome_16s_cli --raw_data <dir> --out_dir <dir> [OPTIONS]"
    echo ""
    echo "Required:"
    echo "  --raw_data <dir>   원본 300bp Paired-end fastq 파일들이 위치한 호스트 절대/상대 경로"
    echo "  --out_dir <dir>    분석 결과가 저장될 호스트 절대/상대 경로"
    echo ""
    echo "Optional:"
    echo "  --metadata <file>  메타데이터 파일 지정 (생략 시 out-dir 내에 자동 생성)"
    echo "  --config <file>    커스텀 config.yaml 파일 지정 (생략 시 기본 workflow/config.yaml 사용)"
    echo "  --cores <num>      할당할 CPU 코어 수 (기본값: all)"
    echo "  --help             도움말 출력"
    exit 1
}

RAW_DATA=""
OUT_DIR=""
METADATA=""
CONFIG_FILE=""
CORES="all"

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --raw_data) RAW_DATA="$2"; shift ;;
        --out_dir) OUT_DIR="$2"; shift ;;
        --metadata) METADATA="$2"; shift ;;
        --config) CONFIG_FILE="$2"; shift ;;
        --cores) CORES="$2"; shift ;;
        --help|-h) show_help ;;
        *) echo "[Error] Unknown parameter: $1"; show_help ;;
    esac
    shift
done

if [ -z "$RAW_DATA" ] || [ -z "$OUT_DIR" ]; then
    echo "[Error] --raw_data 와 --out_dir 은 필수 인자입니다."
    show_help
fi

# 경로 절대경로화
RAW_DATA=$(cd "$RAW_DATA" && pwd)
mkdir -p "$OUT_DIR"
OUT_DIR=$(cd "$OUT_DIR" && pwd)

# 메타데이터 파라미터 처리
METADATA_MNT=""
METADATA_ARG=""
if [ -n "$METADATA" ]; then
    if [ ! -f "$METADATA" ]; then
        echo "[Error] Metadata file not found at: $METADATA"
        exit 1
    fi
    METADATA_DIR=$(dirname "$METADATA")
    METADATA_NAME=$(basename "$METADATA")
    METADATA_DIR=$(cd "$METADATA_DIR" && pwd)
    METADATA_MNT="-v ${METADATA_DIR}:/metadata_dir"
    METADATA_ARG="--config metadata=/metadata_dir/${METADATA_NAME}"
fi

# Config 파라미터 처리
CONFIG_MNT=""
CONFIG_ARG="--configfile workflow/config.yaml"
if [ -n "$CONFIG_FILE" ]; then
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "[Error] Config file not found at: $CONFIG_FILE"
        exit 1
    fi
    CONFIG_DIR=$(dirname "$CONFIG_FILE")
    CONFIG_NAME=$(basename "$CONFIG_FILE")
    CONFIG_DIR=$(cd "$CONFIG_DIR" && pwd)
    CONFIG_MNT="-v ${CONFIG_DIR}:/custom_config_dir"
    CONFIG_ARG="--configfile /custom_config_dir/${CONFIG_NAME}"
fi

# 파이프라인 루트 디렉토리 식별
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PIPELINE_DIR=$(dirname "$SCRIPT_DIR")

echo "======================================================"
echo " Starting Microbiome 16S Pipeline (QIIME2 2026.4)"
echo "======================================================"
echo " Raw Data Dir : $RAW_DATA"
echo " Output Dir   : $OUT_DIR"
if [ -n "$METADATA" ]; then
    echo " Metadata     : $METADATA"
else
    echo " Metadata     : [Auto-Generate at Output Dir]"
fi
if [ -n "$CONFIG_FILE" ]; then
    echo " Config File  : $CONFIG_FILE"
else
    echo " Config File  : [Default: workflow/config.yaml]"
fi
echo " Cores        : $CORES"
echo " Workspace    : $PIPELINE_DIR"
echo "======================================================"

# Docker 실행 명령어
docker run --rm \
    -v "${PIPELINE_DIR}:/workspace" \
    -v "${RAW_DATA}:/raw_data" \
    -v "${OUT_DIR}:/out_data" \
    ${METADATA_MNT} \
    ${CONFIG_MNT} \
    -w /workspace \
    microbiome_qiime2:latest \
    bash -c "snakemake -s workflow/Snakefile ${CONFIG_ARG} --cores $CORES ${METADATA_ARG} --unlock && \
             snakemake -s workflow/Snakefile ${CONFIG_ARG} --cores $CORES ${METADATA_ARG} && \
             echo 'Generating Snakemake Report...' && \
             snakemake -s workflow/Snakefile ${CONFIG_ARG} --cores $CORES ${METADATA_ARG} --report /out_data/report.html && \
             echo 'Generating DAG graph...' && \
             snakemake -s workflow/Snakefile ${CONFIG_ARG} --cores $CORES ${METADATA_ARG} --dag | dot -Tsvg > /out_data/dag.svg"
