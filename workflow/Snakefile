import os
import glob
import multiprocessing

configfile: "workflow/config.yaml"

# ==============================================================================
# CLI에 의해 매핑되는 마운트 경로들
# ==============================================================================
RAW_DIR = "/raw_data"
OUT_DIR = "/out_data"

# 메타데이터 경로 설정: CLI로 주입된 config가 없으면 OUT_DIR 안에 자동 생성
METADATA_PATH = config.get("metadata", f"{OUT_DIR}/metadata.tsv")

# ==============================================================================
# 1. 메타데이터 자동 생성
# ==============================================================================
if not os.path.exists(METADATA_PATH):
    print(f"Warning: 메타데이터 파일({METADATA_PATH})이 없어 자동 생성합니다...")
    os.makedirs(os.path.dirname(METADATA_PATH) or ".", exist_ok=True)
    
    import re
    files = glob.glob(os.path.join(RAW_DIR, "*_R1*.fastq.gz")) + glob.glob(os.path.join(RAW_DIR, "*_1*.fastq.gz"))
    sample_ids = set()
    for f in files:
        b = os.path.basename(f)
        # QIIME2 Casava 1.8 Regex 추출 규칙 반영
        match = re.match(r"^(.+?)(?:_S\d+)?(?:_\d+)?_L\d{3}_R[12]_\d{3}\.fastq\.gz$", b)
        if match:
            sample_ids.add(match.group(1))
        else:
            for token in ["_S", "_R1", "_1"]:
                if token in b:
                    sample_ids.add(b.split(token)[0])
                    break
            else:
                sample_ids.add(b.split(".")[0])
    
    with open(METADATA_PATH, "w") as out:
        out.write("sample-id\tGroup\n")
        out.write("#q2:types\tcategorical\n")
        if sample_ids:
            for sid in sorted(sample_ids):
                out.write(f"{sid}\tDefaultGroup\n")
        else:
            out.write("dummy\tDefaultGroup\n")
    print(f"-> 기본 메타데이터 생성 완료: {METADATA_PATH}")

# ==============================================================================
# 2. Threads 설정
# ==============================================================================
if str(config.get("pipeline", {}).get("threads")).lower() == "auto":
    N_THREADS = multiprocessing.cpu_count()
else:
    N_THREADS = int(config.get("pipeline", {}).get("threads", 1))

# ==============================================================================
# 3. 데이터베이스 설정
# ==============================================================================
DB_CHOICE = config["database"]["choice"].lower()
if DB_CHOICE == "silva":
    DB_SEQS_URL = config["database"]["silva_seqs_url"]
    DB_TAX_URL = config["database"]["silva_tax_url"]
else:
    # fallback default
    DB_SEQS_URL = "https://data.qiime2.org/2024.10/common/silva-138-99-seqs.qza"
    DB_TAX_URL = "https://data.qiime2.org/2024.10/common/silva-138-99-tax.qza"

# ==============================================================================
# Rules (QIIME2 2026.4 버전에 최적화된 명령어 세트)
# ==============================================================================
rule all:
    input:
        f"{OUT_DIR}/import/demux.qzv",
        f"{OUT_DIR}/dada2/table.qzv",
        f"{OUT_DIR}/dada2/rep-seqs.qzv",
        f"{OUT_DIR}/dada2/denoising-stats.qzv",
        f"{OUT_DIR}/phylogeny/rooted-tree.qza",
        f"{OUT_DIR}/diversity/core-metrics-results",
        f"{OUT_DIR}/diversity/alpha-rarefaction.qzv",
        f"{OUT_DIR}/taxonomy/taxa-bar-plots.qzv",
        f"{OUT_DIR}/taxonomy/taxonomy.qza"

rule get_database:
    output:
        ref_seqs = "db/16s_classifiers/ref-seqs.qza",
        ref_tax = "db/16s_classifiers/ref-tax.qza"
    shell:
        """
        mkdir -p db/16s_classifiers
        wget -q -O {output.ref_seqs} {DB_SEQS_URL}
        wget -q -O {output.ref_tax} {DB_TAX_URL}
        """

rule import_data:
    output:
        demux = f"{OUT_DIR}/import/demux.qza",
        demux_viz = f"{OUT_DIR}/import/demux.qzv"
    shell:
        """
        # RAW_DIR 내의 fastq.gz 파일들만 임시 디렉토리로 심볼릭 링크를 걸어 import (메타데이터 등 다른 파일 혼입 방지)
        mkdir -p {OUT_DIR}/import/tmp_fastq
        ln -s {RAW_DIR}/*.fastq.gz {OUT_DIR}/import/tmp_fastq/ 2>/dev/null || cp {RAW_DIR}/*.fastq.gz {OUT_DIR}/import/tmp_fastq/
        
        qiime tools import \
          --type 'SampleData[PairedEndSequencesWithQuality]' \
          --input-path {OUT_DIR}/import/tmp_fastq \
          --input-format CasavaOneEightSingleLanePerSampleDirFmt \
          --output-path {output.demux}
          
        rm -rf {OUT_DIR}/import/tmp_fastq
          
        qiime demux summarize \
          --i-data {output.demux} \
          --o-visualization {output.demux_viz}
        """

rule dada2_denoise:
    input:
        demux = f"{OUT_DIR}/import/demux.qza"
    output:
        table = f"{OUT_DIR}/dada2/table.qza",
        rep_seqs = f"{OUT_DIR}/dada2/rep-seqs.qza",
        stats = f"{OUT_DIR}/dada2/denoising-stats.qza",
        base_transition = f"{OUT_DIR}/dada2/base-transition-stats.qza",
        table_viz = f"{OUT_DIR}/dada2/table.qzv",
        rep_seqs_viz = f"{OUT_DIR}/dada2/rep-seqs.qzv",
        stats_viz = f"{OUT_DIR}/dada2/denoising-stats.qzv",
        feature_freq = f"{OUT_DIR}/dada2/feature-frequencies.qza",
        sample_freq = f"{OUT_DIR}/dada2/sample-frequencies.qza"
    threads: N_THREADS
    params:
        trim_left_f = config["dada2"]["trim_left_f"],
        trunc_len_f = config["dada2"]["trunc_len_f"],
        trim_left_r = config["dada2"]["trim_left_r"],
        trunc_len_r = config["dada2"]["trunc_len_r"],
        trunc_q = config.get("dada2", {}).get("trunc_q", 2)
    shell:
        """
        qiime dada2 denoise-paired \
          --i-demultiplexed-seqs {input.demux} \
          --p-trim-left-f {params.trim_left_f} \
          --p-trunc-len-f {params.trunc_len_f} \
          --p-trim-left-r {params.trim_left_r} \
          --p-trunc-len-r {params.trunc_len_r} \
          --p-trunc-q {params.trunc_q} \
          --p-n-threads {threads} \
          --o-table {output.table} \
          --o-representative-sequences {output.rep_seqs} \
          --o-denoising-stats {output.stats} \
          --o-base-transition-stats {output.base_transition}
          
        qiime feature-table summarize \
          --i-table {output.table} \
          --o-feature-frequencies {output.feature_freq} \
          --o-sample-frequencies {output.sample_freq} \
          --o-summary {output.table_viz} \
          --m-metadata-file {METADATA_PATH}
          
        qiime feature-table tabulate-seqs \
          --i-data {output.rep_seqs} \
          --o-visualization {output.rep_seqs_viz}
          
        qiime metadata tabulate \
          --m-input-file {output.stats} \
          --o-visualization {output.stats_viz}
        """

rule phylogeny:
    input:
        rep_seqs = f"{OUT_DIR}/dada2/rep-seqs.qza"
    output:
        alignment = f"{OUT_DIR}/phylogeny/aligned-rep-seqs.qza",
        masked_alignment = f"{OUT_DIR}/phylogeny/masked-aligned-rep-seqs.qza",
        tree = f"{OUT_DIR}/phylogeny/unrooted-tree.qza",
        rooted_tree = f"{OUT_DIR}/phylogeny/rooted-tree.qza"
    threads: N_THREADS
    shell:
        """
        qiime phylogeny align-to-tree-mafft-fasttree \
          --i-sequences {input.rep_seqs} \
          --p-n-threads {threads} \
          --o-alignment {output.alignment} \
          --o-masked-alignment {output.masked_alignment} \
          --o-tree {output.tree} \
          --o-rooted-tree {output.rooted_tree}
        """

rule taxonomy_classification:
    input:
        rep_seqs = f"{OUT_DIR}/dada2/rep-seqs.qza",
        ref_seqs = "db/16s_classifiers/ref-seqs.qza",
        ref_tax = "db/16s_classifiers/ref-tax.qza"
    output:
        taxonomy = f"{OUT_DIR}/taxonomy/taxonomy.qza",
        search_results = f"{OUT_DIR}/taxonomy/search-results.qza",
        taxa_bar_plots = f"{OUT_DIR}/taxonomy/taxa-bar-plots.qzv"
    threads: N_THREADS
    shell:
        """
        qiime feature-classifier classify-consensus-vsearch \
          --i-query {input.rep_seqs} \
          --i-reference-reads {input.ref_seqs} \
          --i-reference-taxonomy {input.ref_tax} \
          --p-threads {threads} \
          --o-classification {output.taxonomy} \
          --o-search-results {output.search_results}

        qiime taxa barplot \
          --i-table {OUT_DIR}/dada2/table.qza \
          --i-taxonomy {output.taxonomy} \
          --m-metadata-file {METADATA_PATH} \
          --o-visualization {output.taxa_bar_plots}
        """

rule diversity_analysis:
    input:
        rooted_tree = f"{OUT_DIR}/phylogeny/rooted-tree.qza",
        table = f"{OUT_DIR}/dada2/table.qza"
    output:
        core_metrics = directory(f"{OUT_DIR}/diversity/core-metrics-results"),
        alpha_rarefaction = f"{OUT_DIR}/diversity/alpha-rarefaction.qzv"
    threads: N_THREADS
    params:
        sampling_depth = config.get("diversity", {}).get("sampling_depth", 10000),
        max_depth = config.get("diversity", {}).get("alpha_max_depth", 10000)
    shell:
        """
        # Beta Diversity 지표 (Jaccard, Bray-Curtis, UniFrac) 및 PCoA 분석 수행
        qiime diversity core-metrics-phylogenetic \
          --i-phylogeny {input.rooted_tree} \
          --i-table {input.table} \
          --p-sampling-depth {params.sampling_depth} \
          --m-metadata-file {METADATA_PATH} \
          --p-n-jobs-or-threads {threads} \
          --output-dir {output.core_metrics}
          
        # Alpha Rarefaction Plot 생성
        qiime diversity alpha-rarefaction \
          --i-table {input.table} \
          --i-phylogeny {input.rooted_tree} \
          --p-max-depth {params.max_depth} \
          --m-metadata-file {METADATA_PATH} \
          --o-visualization {output.alpha_rarefaction}
        """
